# Copy to .env.local for local dev. DO NOT commit .env.local.

# Launcher login URL — middleware redirects unauthenticated requests here.
# Production: https://xzibit-apps.vercel.app
NEXT_PUBLIC_XZIBIT_APPS_URL=https://xzibit-apps.vercel.app

# Supabase — platform Postgres (project rklzgzyqbajhpjvixlkr, ap-southeast-1).
# Either NEXT_PUBLIC_SUPABASE_URL or SUPABASE_URL works server-side.
NEXT_PUBLIC_SUPABASE_URL=https://rklzgzyqbajhpjvixlkr.supabase.co

# Server-only. NEVER prefix with NEXT_PUBLIC_. Bypasses RLS.
# Set in Vercel project settings + .env.local.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT signing secret — must match the Launcher's value. Verified by
# src/lib/auth.ts (jose jwtVerify) on every /api/* route. Set in Vercel
# project settings (Production, Preview, Development).
JWT_SECRET=your-jwt-secret-here
